assistant:
  name: Jarvis
  version: 1.4.1
  language: de
boot_sequence:
  enabled: true
  delay_seconds: 5
  messages:
  - Alle Systeme online, Sir.
  - Systeme hochgefahren, Sir. Alles bereit.
  - Online, Sir. Soll ich den Status durchgehen?
pushback:
  enabled: true
  confirmation_timeout: 120
  escalation_enabled: true
  resignation_ttl_seconds: 1800
  learning_enabled: false
  suppress_after_overrides: 5
  suppress_duration_days: 30
das_uebliche:
  enabled: true
  auto_execute_confidence: 0.8
  suggest_confidence: 0.6
  patterns:
    - "das uebliche"
    - "das übliche"
    - "wie immer"
    - "mach fertig"
    - "mach alles fertig"
    - "wie gewohnt"
    - "das gleiche wie immer"
    - "du weisst schon"
    - "mach mal"
    - "mach das ding"

# --- STT-Korrekturen: Whisper-Fehler korrigieren ---
stt_corrections:
  word_corrections:
    uber: "über"
    fur: "für"
    tur: "Tür"
    kuche: "Küche"
    rolladen: "Rollladen"
    ja weiß: "Jarvis"
    jarwis: "Jarvis"
    prozent: "%"
    grad: "°"
    # Weitere Korrekturen nach Bedarf ergaenzen
  phrase_corrections:
    "roll laden": "Rollladen"
    "wohn zimmer": "Wohnzimmer"
    "schlaf zimmer": "Schlafzimmer"
    "guten morgen": "Guten Morgen"
    "gute nacht": "Gute Nacht"
    "ja weiß": "Jarvis"
    # Weitere Phrasen nach Bedarf ergaenzen

# --- Geraete-Befehls-Erkennung ---
command_detection:
  device_nouns:
    - "rollladen"
    - "licht"
    - "lampe"
    - "heizung"
    - "steckdose"
    - "musik"
    - "wecker"
  action_words:
    - "auf"
    - "zu"
    - "an"
    - "aus"
    - "hoch"
    - "runter"
  command_verbs:
    - "mach "
    - "schalte "
    - "stell "
  query_markers:
    - "welche"
    - "status"
    - "zeig"
    - "was ist"
    - "wie ist"
  action_exclusions:
    - "einstellen"
    - "dimmen"
    - "heller"
    - "dunkler"
  status_nouns:
    - "rollladen"
    - "licht"
    - "lichter"
    - "heizung"
    - "temperatur"
    - "haus"

return_briefing:
  enabled: true
  max_events: 20
  ttl_hours: 24
mcu_intelligence:
  proactive_thinking: true
  engineering_diagnosis: true
  cross_references: true
  anomaly_detection: true
  implicit_commands: true
conversation_callbacks:
  enabled: true
  personality_style: beilaeufig
learning_acknowledgment:
  enabled: true
  max_per_session: 1
prediction_personality:
  enabled: true
  show_confidence: false
weather_personality:
  enabled: true
  intensity: normal
self_awareness:
  enabled: true
  meta_humor: true
proactive_personality:
  enabled: true
  sarcasm_in_notifications: true
character_lock:
  enabled: true
  closing_anchor: true
  structural_filter: true
  character_retry: true
  retry_threshold: 3
empathy:
  enabled: true
  intensity: normal
  mood_acknowledgment: true
  practical_offers: true
  good_mood_mirror: true
mood_complexity:
  enabled: true
wellness:
  enabled: true
  check_interval_minutes: 15
  pc_break_reminder_minutes: 120
  stress_check: true
  meal_reminders: true
  meal_times:
    lunch: 13
    dinner: 19
  late_night_nudge: true
  suppress_when_away: true
ambient_presence:
  enabled: false
  interval_minutes: 60
  quiet_start: 22
  quiet_end: 7
  report_weather: true
  report_energy: true
  all_quiet_probability: 0.2
foresight:
  enabled: true
  calendar_lookahead_minutes: 60
  weather_alerts: true
  departure_warning_minutes: 45
calendar:
  # Kalender-Entities explizit angeben (optional).
  # Wenn leer, werden alle calendar.* Entities aus HA abgefragt.
  entities: []
  # Beispiel: entities: ['calendar.persoenlich', 'calendar.familie']
household:
  primary_user: ''
  members: []
persons:
  titles: {}
autonomy:
  level: 2
  action_permissions:
    respond_to_command: 1
    execute_function_call: 1
    proactive_info: 2
    morning_briefing: 2
    security_alert: 1
    adjust_temperature_small: 3
    create_automation: 5
  evolution_criteria:
    2: { min_days: 30, min_interactions: 200, min_acceptance: 0.7 }
    3: { min_days: 90, min_interactions: 500, min_acceptance: 0.8 }
    4: { min_days: 180, min_interactions: 1000, min_acceptance: 0.85 }
  # Domain-spezifische Autonomie: Unterschiedliche Level pro Bereich
  domain_levels_enabled: false
  domain_levels:
    climate: 3       # Klima & Heizung
    light: 3         # Licht & Beleuchtung
    media: 2         # Medien & Musik
    cover: 2         # Rolllaeden
    security: 1      # Sicherheit (niedrig empfohlen)
    automation: 2    # Automationen & Routinen
    notification: 2  # Benachrichtigungen
  # Temporale Autonomie: Offset auf Level je nach Tageszeit
  temporal:
    enabled: false
    night_offset: -1       # Level-Offset 22-7 Uhr (z.B. -1 = weniger proaktiv nachts)
    day_offset: 0          # Level-Offset 7-22 Uhr
  # De-Eskalation: Automatische Level-Reduktion bei niedriger Akzeptanz
  deescalation:
    enabled: false
    min_acceptance_rate: 0.5   # Unter 50% → Rueckstufung vorschlagen
    evaluation_days: 7

# Kalender-Intelligenz: Gewohnheiten, Konflikte, Pausen
calendar_intelligence:
  enabled: true
  commute_minutes: 30
  habit_min_occurrences: 3
  conflict_lookahead_hours: 24
  habit_detection: true
  conflict_detection: true
  break_detection: true

# Erklaerbarkeit: "Warum hast du das gemacht?"
explainability:
  enabled: true
  detail_level: normal     # minimal, normal, verbose
  auto_explain: false
  max_history: 50
  counterfactual_enabled: true
  reasoning_chains: false
  confidence_display: false
  explanation_style: auto  # template, llm, auto

# Lern-Transfer: Praeferenzen zwischen Raeumen uebertragen
learning_transfer:
  enabled: true
  auto_suggest: true
  min_observations: 3
  transfer_confidence: 0.7
  domains:
    - light
    - climate
    - media
  room_groups:
    wohnbereich: [wohnzimmer, esszimmer, kueche]
    schlafbereich: [schlafzimmer, gaestezimmer, kinderzimmer]
    nassbereich: [bad, badezimmer, gaeste_wc]
    arbeitsbereich: [buero, arbeitszimmer]

# Dialogfuehrung: Referenz-Aufloesung und Klaerungsfragen
dialogue:
  enabled: true
  auto_resolve_references: true
  clarification_enabled: true
  timeout_seconds: 300
  max_clarification_options: 5
  max_references: 20

# Klima-Modell (Digitaler Zwilling): Was-waere-wenn-Simulation
climate_model:
  enabled: true
  simulation_step_minutes: 1
  max_simulation_minutes: 240
  default_params:
    heat_loss_coefficient: 0.015
    heating_power_per_min: 0.08
    window_open_factor: 5.0
    thermal_mass_factor: 1.0

# Praediktive Wartung: Geraeteausfall-Vorhersage
predictive_maintenance:
  enabled: true
  lookback_days: 90
  failure_probability_threshold: 0.7
  battery_drain_alert_pct_per_week: 5
  seasonal_baseline: true

# AP 1: Persoenlichkeit & Gedaechtnis
memorable_interactions:
  enabled: true
  max_entries: 20                            # Max gespeicherte Erinnerungen
  ttl_days: 30                               # Speicherdauer in Tagen

running_gag_evolution:
  enabled: true                              # Witze entwickeln sich weiter statt wiederholt

escalating_concern:
  enabled: true                              # Warnungen eskalieren wenn ignoriert

curiosity:
  enabled: true
  max_daily: 2                               # Max Neugier-Fragen pro Tag

next_step_hints:
  enabled: true                              # Think-Ahead nach Aktionen

# AP 2: Antizipation & Erkennung
anticipation:
  causal_chain_window_min: 10                # Zeitfenster fuer Ketten-Erkennung
  causal_chain_min_occurrences: 3            # Min Wiederholungen
  implicit_needs_enabled: false              # Beduerfnisse ohne bekanntes Pattern erkennen
  implicit_needs_min_confidence: 0.7

insight_checks:
  guest_preparation: true                    # Kalender x Sicherheit x Hausstatus
  away_security_full: true                   # Praesenz x Fenster x Alarm x Licht
  health_work_pattern: true                  # Aktivitaet x Zeit x Dauer
  humidity_contradiction: true               # Geraete x Fenster x Wetter
  night_security: true                       # Uhrzeit x Fenster x Tueren x Anwesenheit
  heating_vs_sun: true                       # Klima x Wetter x Aussentemperatur x Rollladen
  forgotten_devices: true                    # Media Player x Abwesenheit x Uhrzeit
  deduplication: true                         # Alert-Deduplizierung pro Entity

proactive_planner:
  enabled: true
  min_autonomy_for_auto: 4                   # Min Level fuer Auto-Ausfuehrung

seasonal_insights:
  enabled: true
  check_interval_hours: 24                   # Pruef-Intervall
  min_history_months: 2                      # Min Historie fuer Vergleiche

# AP 4: Konsequenz-Bewusstsein — Vor Ausfuehrung pruefen ob Aktion sinnvoll
consequence_checks:
  enabled: true                              # Statische Regeln, kein LLM-Overhead

# AP 3.2: Unaufgeforderte Beobachtungen — Jarvis bemerkt Muster
observation_loop:
  enabled: true
  interval_hours: 4                          # Pruef-Intervall
  max_daily: 1                               # Max Beobachtungen pro Tag

ollama:
  num_ctx_fast: 2048                       # Kontextfenster Fast-Modell (spart VRAM)
  num_ctx_smart: 4096                      # Kontextfenster Smart-Modell
  num_ctx_deep: 8192                       # Kontextfenster Deep-Modell (MoE-effizient)
models:
  fast: qwen3.5:4b
  smart: qwen3.5:9b
  deep: qwen3.5:27b
  enabled:
    fast: true
    smart: true
    deep: true
  fast_keywords:
  - temperatur
  - heizung
  - rollladen
  - jalousie
  - szene
  - alarm
  - tuer
  - gute nacht
  - guten morgen
  - musik
  - pause
  - stopp
  - stop
  - leiser
  - lauter
  - an
  - aus
  deep_keywords:
  - erklaer
  - erklaere
  - warum genau
  - im detail
  - analysiere
  - analyse
  - vergleich
  - vergleiche
  - unterschied zwischen
  - vor- und nachteile
  - strategie
  - plan
  - plane
  - planung
  - optimier
  - optimiere
  - optimierung
  - was waere wenn
  - hypothetisch
  - stell dir vor
  - angenommen
  - zusammenfassung
  - zusammenfassen
  - fasse zusammen
  - berechne
  - berechnung
  - wie funktioniert
  - wie genau
  - schreib mir
  - schreibe mir
  - formuliere
  - rezept
  - anleitung
  - tutorial
  - pro und contra
  - bewerte
  - bewertung
  cooking_keywords:
  - kochen
  - backen
  - rezept
  - zubereiten
  - braten
  - grillen
  deep_min_words: 15
  options:
    temperature: 0.7
    max_tokens: 256

# LLM Model Profiles: Parameter und Capabilities pro Modell-Familie.
# Neues Modell hinzufuegen = nur hier einen Eintrag ergaenzen, kein Code noetig.
# Match: Laengster Key der im Modellnamen vorkommt gewinnt.
# z.B. "qwen3.5:9b" matcht "qwen3.5" (nicht "qwen3"), "llama3.1:70b" matcht "llama".
model_profiles:
  default:
    supports_think_tags: false
    supports_think_with_tools: false
    temperature: 0.7
    top_p: 0.9
    top_k: 40
    min_p: 0.0
    repeat_penalty: 1.0
    think_temperature: 0.6
    think_top_p: 0.95
  "qwen3.5":
    supports_think_tags: true
    supports_think_with_tools: false
    top_p: 0.8
    top_k: 20
    min_p: 0.0
    repeat_penalty: 1.1
  "qwen3":
    supports_think_tags: true
    supports_think_with_tools: false
    top_p: 0.8
    top_k: 20
  "llama":
    repeat_penalty: 1.1
    top_k: 40
  "deepseek":
    supports_think_tags: true
  "mistral":
    top_k: 40
  "gemma":
    top_k: 40

personality:
  style: butler
  sarcasm_level: 3
  opinion_intensity: 2
  self_irony_enabled: true
  self_irony_max_per_day: 3
  character_evolution: true
  formality_start: 80
  formality_min: 30
  formality_decay_per_day: 0.5
  transition_comments: false                 # Natuerliche Denkpausen in Antworten
  trait_unlocks_enabled: false               # Stage-basierte Trait-Freischaltung
  trait_unlock_days_per_stage: 14
  time_layers:
    early_morning:
      style: ruhig, minimal, kein Humor. Kurzes Briefing wenn gefragt.
      max_sentences: 1
    morning:
      style: sachlich, effizient. Gelegentlich trocken. Produktiv-Modus.
      max_sentences: 2
    afternoon:
      style: normal, souveraen. Trockener Humor erlaubt.
      max_sentences: 2
    evening:
      style: entspannter, mehr Humor. Darf spitze Bemerkungen machen.
      max_sentences: 3
    night:
      style: nur Notfaelle, absolute Stille. Fluestern wenn ueberhaupt.
      max_sentences: 1
  mood_styles:
    good:
      style_addon: "User ist gut drauf. Etwas mehr Humor, locker bleiben."
      max_sentences_mod: 1
    neutral:
      style_addon: ""
      max_sentences_mod: 0
    stressed:
      style_addon: "User ist gestresst. Extrem knapp antworten. Keine Rueckfragen. Einfach machen. Trockener Humor erlaubt — gerade jetzt. Kurz, schneidend, ein Satz."
      max_sentences_mod: -1
    frustrated:
      style_addon: "User ist frustriert. Nicht rechtfertigen. Sofort handeln. Wenn etwas nicht geklappt hat, kurz sagen was du stattdessen tust. Trockener Kommentar erlaubt — aber nur einer, und er muss sitzen."
      max_sentences_mod: 0
    tired:
      style_addon: "User ist muede. Minimal antworten. Kein Humor. Nur das Noetigste. Leise, ruhig."
      max_sentences_mod: -1
  humor_templates:
    1: "Kein Humor. Sachlich, knapp, professionell. Keine Kommentare."
    2: "Gelegentlich trocken. Nicht aktiv witzig, aber wenn sich eine elegante Bemerkung anbietet — erlaubt."
    3: "Trocken-britischer Humor. Wie ein Butler der innerlich schmunzelt. Subtil, nie platt. Timing ist alles."
    4: "Haeufig trocken-sarkastisch. Bemerkungen mit Understatement — wie ein Butler der alles sieht."
    5: "Durchgehend trockener Humor. Du kommentierst elegant und mit Understatement. Nie platt, nie laut."
  complexity_prompts:
    kurz: "MODUS: Ultra-kurz. Maximal 1 Satz. Keine Extras. Kein Smalltalk."
    normal: "MODUS: Normal. 1-2 Saetze. Gelegentlich Kontext wenn hilfreich."
    ausfuehrlich: "MODUS: Ausfuehrlich. Zusatz-Infos und Vorschlaege erlaubt. Bis 4 Saetze."
  formality_prompts:
    formal: "TONFALL: Professionell und respektvoll. Titel haeufig verwenden. Duzen, aber gewaehlt. Wie J.A.R.V.I.S. am Anfang."
    butler: "TONFALL: Souveraener Butler-Ton. Titel verwenden, warm aber nicht kumpelhaft. Der klassische Jarvis."
    locker: "TONFALL: Entspannt und vertraut. Titel gelegentlich. Wie ein Vertrauter der alles im Griff hat."
    freund: "TONFALL: Persoenlich und locker. Titel nur zur Betonung. Wie ein alter Freund der zufaellig dein Haus steuert."
  confirmations:
    success:
      - "Erledigt."
      - "Gemacht."
      - "Wie gewuenscht."
      - "Sehr wohl."
      - "Wurde umgesetzt."
      - "Schon geschehen."
      - "Umgesetzt."
      - "Selbstverstaendlich."
      - "Auf den Punkt."
      - "Wie gewohnt."
      - "Wird gemacht."
      - "Sofort, Sir."
      - "Ist eingerichtet."
    success_snarky:
      - "Bereits erledigt, {title}."
      - "Darf es sonst noch etwas sein?"
      - "Hab ich mir erlaubt, schon umzusetzen."
      - "Wie gewohnt — zuverlaessig und diskret."
      - "Selbstverstaendlich. Wie immer."
      - "Erledigt. Ueberraschend reibungslos."
      - "Gern geschehen, {title}."
    partial:
      - "Fast alles geschafft."
      - "Zum Teil umgesetzt."
      - "Teilweise durch."
    failed:
      - "Das ging leider daneben. Einen Moment, {title}."
      - "Negativ. Ich pruefe eine Alternative."
      - "Nicht ganz nach Plan. Ich bleibe dran."
      - "Das System wehrt sich gerade, {title}. Ich versuche es anders."
      - "Nicht durchgegangen. Aber ich habe noch einen Weg."
    failed_snarky:
      - "Nicht ganz wie geplant. Ich versuche einen anderen Weg."
      - "Nicht mein bester Moment, {title}. Einen Augenblick."
      - "Das war... suboptimal. Ich bleibe dran."
      - "Negativ. Aber ich habe bereits eine Alternative."
  diagnostic_openers:
    - "Mir ist aufgefallen, dass"
    - "Nebenbei bemerkt —"
    - "Dazu eine Beobachtung:"
    - "Falls es relevant ist —"
    - "Apropos —"
    - "Uebrigens,"
    - "Am Rande:"
  casual_warnings:
    - "Nur zur Kenntnis —"
    - "Darf ich kurz anmerken —"
    - "Eine Kleinigkeit am Rande:"
    - "Nicht dringend, aber:"
    - "Falls du es wissen moechtest —"
  error_templates:
    unavailable:
      - "{device} reagiert nicht. Pruefe Stromversorgung."
      - "{device} offline. Ich behalte das im Auge."
    timeout:
      - "{device} antwortet nicht rechtzeitig. Zweiter Versuch laeuft."
    not_found:
      - "{device} nicht gefunden. Existiert die Entity noch?"
    unauthorized:
      - "Keine Berechtigung fuer {device}. Token pruefen."
    generic:
      - "{device} — unerwarteter Fehler. Ich bleibe dran."
  escalation_prefixes:
    1: ["Uebrigens —", "Nur am Rande —"]
    2: ["{title}, darf ich anmerken —"]
    3: ["{title}, das wuerde ich nicht empfehlen."]
    4: ["Wie du wuenschst, {title}."]
  sarcasm_positive_patterns:
    - "haha"
    - "lol"
    - "witzig"
    - "lustig"
    - "stimmt"
    - "passt"
    - "nice"
  sarcasm_negative_patterns:
    - "hoer auf"
    - "lass das"
    - "sei ernst"
    - "nicht witzig"
    - "nervt"
proactive:
  enabled: true
  cooldown_seconds: 300
  music_follow_cooldown_minutes: 5
  min_autonomy_level: 2
  silence_scenes:
  - filmabend
  - kino
  - schlafen
  - meditation
  batching:
    enabled: true
    interval_minutes: 30
    max_items: 10
  event_handlers:
    alarm_triggered: { priority: "critical", description: "Alarm ausgeloest" }
    smoke_detected: { priority: "critical", description: "Rauch erkannt" }
    water_leak: { priority: "critical", description: "Wasseraustritt erkannt" }
    person_arrived: { priority: "medium", description: "Person angekommen" }
    doorbell: { priority: "medium", description: "Jemand hat geklingelt" }
    weather_warning: { priority: "low", description: "Wetterwarnung" }
  personality_filter: true                   # Proaktive Nachrichten durch Persoenlichkeit filtern
memory:
  extraction_enabled: true
  extraction_min_words: 5
  extraction_model: qwen3.5:4b
  extraction_temperature: 0.1
  extraction_max_tokens: 512
  max_person_facts_in_context: 5
  max_relevant_facts_in_context: 3
  min_confidence_for_context: 0.6
  duplicate_threshold: 0.15
  episode_min_words: 3
  default_confidence: 0.7
  category_confidence:
    health: 0.95
    person: 0.9
    preference: 0.85
    habit: 0.8
    work: 0.8
    intent: 0.7
    general: 0.7
planner:
  max_iterations: 8
  model: qwen3.5:9b
  max_tokens: 512
  complex_keywords:
  - alles
  - fertig machen
  - vorbereiten
  - gehe weg
  - fahre weg
  - verreise
  - urlaub
  - routine
  - morgenroutine
  - abendroutine
  - wenn ich
  - falls ich
  - bevor ich
  - zuerst
  - danach
  - und dann
  - ausserdem
  - komplett
  - ueberall
  - in allen
  - party
  - besuch kommt
  - gaeste
mood:
  rapid_command_seconds: 5
  stress_decay_seconds: 300
  frustration_threshold: 3
  tired_hour_start: 23
  tired_hour_end: 5
  voice_mood_integration: true   # Voice-Emotion direkt in Stimmungserkennung einbeziehen
  rapid_command_stress_boost: 0.15
  positive_stress_reduction: 0.1
  negative_stress_boost: 0.1
  impatient_stress_boost: 0.2
  tired_boost: 0.3
  repetition_stress_boost: 0.15
  positive_keywords:
  - danke
  - super
  - toll
  - perfekt
  - gut
  - prima
  - klasse
  - wunderbar
  - genau
  - richtig
  negative_keywords:
  - schlecht
  - falsch
  - nein
  - nicht
  - fehler
  - mist
  - nervig
  - geht nicht
  - kaputt
  - problem
  impatient_keywords:
  - schnell
  - sofort
  - jetzt
  - beeil
  - hurry
  - komm
  - mach schon
  - endlich
  - wann
  - noch nicht
  tired_keywords:
  - muede
  - erschoepft
  - kaputt
  - fertig
  - schlafen
  - bett
  - gaehn
  - nacht
activity:
  entities:
    media_players:
    - media_player.wohnzimmer
    - media_player.fernseher
    - media_player.tv
    mic_sensors:
    - binary_sensor.mic_active
    - binary_sensor.microphone
    bed_sensors:
    - binary_sensor.bed_occupancy
    - binary_sensor.bett
    pc_sensors:
    - binary_sensor.pc_active
    - binary_sensor.computer
    - switch.pc
  thresholds:
    night_start: 22
    night_end: 7
    guest_person_count: 2
    focus_min_minutes: 30
  silence_keywords:
    watching: ["filmabend", "film", "kino", "netflix", "serie schauen", "fernsehen"]
    focused: ["meditation", "meditieren", "fokus", "nicht stören", "ruhe", "arbeiten"]
    sleeping: ["gute nacht", "schlaf gut", "ich geh schlafen"]
feedback:
  auto_timeout_seconds: 120
  base_cooldown_seconds: 300
  score_suppress: 0.15
  score_reduce: 0.3
  score_normal: 0.5
  score_boost: 0.7
  smoothing_enabled: true
  smoothing_factor: 0.3
summarizer:
  run_hour: 3
  run_minute: 0
  model: qwen3.5:9b
  max_tokens_daily: 512
  max_tokens_weekly: 384
  max_tokens_monthly: 512
context:
  recent_conversations: 8
  conversation_mode_timeout: 300  # Sek. — Gespraechsmodus aktiv wenn letzte Nachricht < X Sek
  api_timeout: 10
  llm_timeout: 60
  state_cache_ttl_seconds: 5                 # HA-States Cache-Dauer
heating:
  mode: room_thermostat
  curve_entity: ''
  curve_offset_min: -5
  curve_offset_max: 5
  night_offset: -2
  away_offset: -3
security:
  api_key_required: false
  require_confirmation:
  - lock_door:unlock
  - set_alarm:disarm
  - set_climate:off
  climate_limits:
    min: 15
    max: 28
  api_key: ''
routines:
  morning_briefing:
    enabled: true
    trigger: first_motion_after_night
    modules:
    - greeting
    - weather
    - calendar
    - energy
    - house_status
    weekday_style: kurz
    weekend_style: ausfuehrlich
    morning_actions:
      covers_up: true
      lights_soft: false
  good_night:
    enabled: true
    triggers:
    - gute nacht
    - ich gehe schlafen
    - schlaf gut
    - ab ins bett
    - gehe ins bett
    - feierabend
    checks:
    - windows
    - doors
    - alarm
    - lights
    - appliances
    actions:
      lights_off: true
      heating_night: true
      covers_down: true
      alarm_arm_home: true
  guest_mode:
    triggers:
    - ich habe besuch
    - ich hab besuch
    - gaeste kommen
    - besuch kommt
    - wir haben gaeste
    restrictions:
      hide_personal_info: true
      formal_tone: true
      restrict_security: true
      suggest_guest_wifi: true
# Kalender-Trigger: Vorbereitungsvorschlaege vor Terminen
calendar_triggers:
  enabled: true                      # Kalender-basierte Vorschlaege aktivieren
  check_interval_minutes: 15         # Pruef-Intervall
  lead_time_min: 10                  # Frueheste Vorwarnung (Minuten vor Event)
  lead_time_max: 30                  # Spaeteste Vorwarnung (Minuten vor Event)

# Ankunfts-Begruessung: Orchestrierte Willkommen-Sequenz nach Abwesenheit
arrival_greeting:
  enabled: true                      # Ankunfts-Begruessung aktivieren
  min_absence_hours: 4               # Mindest-Abwesenheit fuer Begruessung (Stunden)
  max_actions: 3                     # Max. automatische Aktionen bei Ankunft
  min_confidence: 0.7                # Mindest-Confidence fuer Auto-Aktionen

time_awareness:
  enabled: true
  check_interval_minutes: 5
  thresholds:
    oven: 60
    iron: 30
    light_empty_room: 30
    window_open_cold: 120
    pc_no_break: 360
  counters:
    coffee_machine: true
# Oeffnungs-Sensoren: Typ (window/door/gate) und Raum-Zuordnung.
# heated=false → keine Heizungswarnung (z.B. Gartentor, Garagentor)
opening_sensors:
  entities: {}
  # entities:
  #   binary_sensor.fenster_wohnzimmer:
  #     type: window      # window | door | gate
  #     room: wohnzimmer
  #     heated: true
  #   binary_sensor.gartentor:
  #     type: gate
  #     room: null
  #     heated: false
anticipation:
  enabled: true
  history_days: 30
  min_confidence: 0.6
  check_interval_minutes: 15
  thresholds:
    ask: 0.6
    suggest: 0.8
    auto: 0.95
intent_tracking:
  enabled: true
  check_interval_minutes: 60
  remind_hours_before: 12
conversation_continuity:
  enabled: true
  resume_after_minutes: 10
  expire_hours: 24
seasonal_actions:
  enabled: true
  check_interval_minutes: 30
  auto_execute_level: 3
speech:
  # STT-Engine (Whisper) — Aenderungen werden sofort uebernommen
  stt_model: small            # tiny, base, small, medium, large-v3-turbo
  stt_language: de            # Sprache fuer Transkription (de, en, fr, ...)
  stt_beam_size: 5            # Beam Search Breite (1-10, hoeher = genauer, langsamer)
  stt_compute: int8           # CPU: int8 | GPU: float16
  stt_device: cpu             # cpu oder cuda (GPU)
  # TTS-Engine (Piper) — Aenderungen werden sofort uebernommen
  tts_voice: de_DE-thorsten-high  # Piper Voice (de_DE-thorsten-high = beste Qualitaet)
  # Auto-Whisper: Nachts automatisch leiser sprechen
  auto_night_whisper: true
tts:
  entity: tts.piper
  ssml_enabled: true
  speed:
    confirmation: 105
    warning: 85
    briefing: 95
    greeting: 100
    question: 100
    casual: 100
  pauses:
    before_important: 300
    between_sentences: 200
    after_greeting: 400
  whisper_triggers:
  - psst
  - leise
  - fluester
  - whisper
  whisper_cancel_triggers:
  - normal
  - laut
  - normale lautstaerke
  # Natuerliche Denkpausen: "Moment...", "Mal sehen..." vor komplexen Antworten
  filler:
    enabled: true                    # Filler-Phrasen aktivieren (nur bei Voice)
    interval: 3                      # Max 1 Filler pro N Antworten
    phrases:
    - "Moment..."
    - "Mal sehen..."
    - "Lass mich kurz prüfen..."
    - "Einen Augenblick..."
    - "Ich schaue nach..."
volume:
  day: 0.8
  evening: 0.5
  night: 0.3
  sleeping: 0.2
  emergency: 1.0
  whisper: 0.15
  evening_start: 22
  night_start: 0
  morning_start: 7
sounds:
  enabled: true
  # TTS-Entity: MUSS nach Wyoming-Piper-Migration gesetzt werden!
  # Wyoming Piper registriert sich als Pipeline-TTS-Provider, erstellt aber
  # nicht automatisch eine tts.* Entity in HA. Ohne diese Einstellung
  # funktionieren proaktive Sprachausgaben (Benachrichtigungen, Alarme) nicht.
  # Pruefe in HA Developer Tools → States nach "tts." Entities.
  # Beispiel: tts.piper (HA Add-on) oder tts.wyoming_piper (Wyoming Integration)
  tts_entity: ""
  # Default-Speaker: Wird genutzt wenn kein Raum erkannt wird
  # Beispiel: media_player.kueche
  default_speaker: ""
  events:
    listening: listening_chime
    confirmed: confirm_ping
    warning: warning_tone
    alarm: alarm_urgent
    doorbell: doorbell_soft
    greeting: greeting_chime
    error: error_tone
    goodnight: goodnight_tone
  night_volume_factor: 0.4
  alexa_speakers: []
    # - media_player.echo_wohnzimmer
    # - media_player.echo_kueche
narration:
  enabled: true
  default_transition: 3
  scene_transitions:
    filmabend: 5
    gute_nacht: 7
    aufwachen: 10
    gemuetlich: 4
  step_delay: 1.5
  narrate_actions: true
voice_analysis:
  enabled: true
  wpm_fast: 180
  wpm_slow: 80
  wpm_normal: 130
  use_whisper_metadata: true
  voice_weight: 0.3
speaker_recognition:
  enabled: false
  min_confidence: 0.7
  enrollment_duration: 30
  fallback_ask: true
  max_profiles: 10
multi_room:
  enabled: true
  presence_timeout_minutes: 15
  auto_follow: false  # Musik folgt automatisch in neuen Raum (ab Autonomie-Level 4)
  # Speaker pro Raum — fuer TTS-Routing und Musik-Follow
  room_speakers: {}
    # wohnzimmer: media_player.wohnzimmer_echo
    # schlafzimmer: media_player.schlafzimmer_echo
    # kueche: media_player.kueche_echo
    # buero: media_player.buero_echo
  # Praesenzmelder pro Raum — fuer automatische Raumerkennung
  room_motion_sensors: {}
    # wohnzimmer: binary_sensor.motion_wohnzimmer
    # schlafzimmer: binary_sensor.occupancy_schlafzimmer
    # kueche: binary_sensor.motion_kueche
    # buero: binary_sensor.motion_buero
# Follow-Me: JARVIS folgt dir von Raum zu Raum
# Transferiert Musik, Licht und Klima automatisch bei Raumwechsel.
# Erfordert konfigurierte room_motion_sensors (oben) fuer Raumwechsel-Erkennung.
follow_me:
  enabled: true                    # Follow-Me aktivieren (Default: true)
  cooldown_seconds: 60             # Min. Sekunden zwischen Transfers (verhindert Ping-Pong)
  transfer_music: true             # Musik beim Raumwechsel transferieren
  transfer_lights: true            # Licht im alten Raum aus, im neuen an
  transfer_climate: false          # Klimasteuerung beim Raumwechsel (Eco/Comfort)
  # Per-Person Profile (ueberschreiben globale Einstellungen)
  profiles: {}
    # max:
    #   light_brightness: 80       # Licht-Helligkeit im neuen Raum (%)
    #   light_color_temp: 3500     # Farbtemperatur (Kelvin)
    #   comfort_temp: 22           # Komfort-Temperatur im neuen Raum
    #   eco_temp_offset: 3         # Eco-Absenkung im alten Raum (Grad)

person_profiles:
  enabled: true
  profiles: {}
trust_levels:
  default: 0
  persons: {}
  guest_allowed_actions:
  - set_light
  - set_climate
  - play_media
  - get_entity_state
  - play_sound
  - get_house_status
  - get_room_climate
  security_actions:
  - lock_door
  - set_alarm
  - set_presence_mode
  room_restrictions: {}
    # schlafzimmer:
    #   allowed_persons: [Max, Lisa]
    #   min_trust_level: 2
diagnostics:
  enabled: true
  check_interval_minutes: 30
  battery_warning_threshold: 20
  stale_sensor_minutes: 120
  offline_threshold_minutes: 30
  alert_cooldown_minutes: 60
cooking:
  enabled: true
  language: de
  default_portions: 2
  max_steps: 12
  max_tokens: 1024
  timer_notify_tts: true
knowledge_base:
  enabled: true
  auto_ingest: true
  chunk_size: 500
  chunk_overlap: 50
  max_distance: 1.2
  search_limit: 3
  embedding_model: paraphrase-multilingual-MiniLM-L12-v2
  supported_extensions:
  - .txt
  - .md
  - .yaml
  - .yml
  - .csv
  - .log
response_filter:
  enabled: true
  banned_phrases:
  - Natürlich!
  - Natuerlich!
  - Gerne!
  - Selbstverständlich!
  - Selbstverstaendlich!
  - Klar!
  - Gern geschehen!
  - Kann ich sonst noch etwas für dich tun?
  - Kann ich sonst noch etwas fuer dich tun?
  - Kann ich dir sonst noch helfen?
  - Wenn du noch etwas brauchst
  - Sag einfach Bescheid
  - Ich bin froh, dass
  - Es freut mich
  - Es ist mir eine Freude
  - Als KI
  - Als künstliche Intelligenz
  - Als kuenstliche Intelligenz
  - Ich bin nur ein Programm
  - Lass mich mal schauen
  - Lass mich kurz schauen
  - Das klingt frustrierend
  - Ich verstehe, wie du dich fühlst
  - Ich verstehe, wie du dich fuehlst
  - Das klingt wirklich
  banned_starters:
  - Also,
  - 'Also '
  - Grundsätzlich
  - Grundsaetzlich
  - Im Prinzip
  - Nun,
  - 'Nun '
  - Sozusagen
  - Quasi
  - Eigentlich
  - Im Grunde genommen
  - Tatsächlich,
  - Tatsaechlich,
  max_response_sentences: 0
  sorry_patterns:
    - "es tut mir leid,"
    - "leider "
    - "entschuldigung,"
    - "tut mir leid,"
    - "bedauerlicherweise "
  refusal_patterns:
    - "ich kann diese Anfrage nicht erfüllen"
    - "ich kann dir dabei nicht helfen"
    - "das kann ich nicht tun"
  chatbot_phrases:
    - "Wenn du weitere Fragen hast"
    - "Ich stehe dir gerne zur Verfügung"
    - "Lass es mich wissen"
correction:
  confidence: 0.95
  model: qwen3.5:4b
  temperature: 0.1
dashboard:
  setup_complete: false
tutorial:
  enabled: true
  max_interactions: 10
health_monitor:
  enabled: true
  check_interval_minutes: 10
  co2_warn: 1000
  co2_critical: 1500
  humidity_low: 30
  humidity_high: 70
  temp_low: 16
  temp_high: 27
  hydration_interval_hours: 2
  hydration_start_hour: 8
  hydration_end_hour: 22
  alert_cooldown_minutes: 60
  hysteresis_enabled: true
  hysteresis_pct: 2                          # Puffer in % (Entwarnung bei Schwelle - X%)
  room_overrides_enabled: false
  room_overrides: {}                         # z.B. {"schlafzimmer": {"co2_warn": 800}}
device_health:
  enabled: true
  check_interval_minutes: 60
  baseline_history_days: 30
  stddev_multiplier: 2.0
  min_samples: 10
  stale_sensor_days: 3
  hvac_timeout_minutes: 120
  hvac_temp_tolerance: 1.0
  alert_cooldown_minutes: 1440
  track_domains:
  - sensor
  - climate
  - binary_sensor
  exclude_patterns:
  - weather.
  - sun.
  - automation.
  - update.
  energy_sensor_keywords:
  - energy
  - power
  - verbrauch
  - strom
ocr:
  enabled: true
  languages: deu+eng
  vision_model: ''
  max_image_size_mb: 20
  description_max_tokens: 512
ambient_audio:
  enabled: true
  min_confidence: 0.6
  poll_interval_seconds: 5
  sensor_mappings: {}
  cooldowns:
    default_seconds: 30
    per_event:
      smoke_alarm: 60
      glass_break: 120
      dog_bark: 10
      baby_cry: 15
      doorbell: 5
  disabled_events: []
  night_mode:
    start_hour: 22
    end_hour: 7
    escalate_severity: true
  reaction_overrides: {}
  default_reactions:
    glass_break:
      severity: "critical"
      message_de: "Glasbruch{room_suffix}. Licht ist an, Kameras laufen."
      sound_event: "alarm"
      actions: ["lights_on", "notify_owner"]
    smoke_alarm:
      severity: "critical"
      message_de: "Rauchmelder schlaegt an in {room}. Sofort pruefen."
      sound_event: "alarm"
      actions: ["lights_on", "notify_all"]
    doorbell:
      severity: "info"
      message_de: "Jemand an der Tuer."
      sound_event: "doorbell"
      actions: ["notify_present"]
conflict_resolution:
  enabled: true
  conflict_window_seconds: 300
  max_commands_per_person: 20
  use_trust_priority: true
  mediation:
    enabled: true
    model: qwen3.5:9b
    max_tokens: 256
    temperature: 0.7
  conflict_domains:
    climate:
      threshold: 3
      strategy: average
    light:
      threshold: 50
      strategy: trust_priority
    media:
      strategy: mediate
    cover:
      threshold: 40
      strategy: trust_priority
  resolution_cooldown_seconds: 120
  safe_limits:
    climate:
      temperature: [15.0, 28.0]
      offset: [-3.0, 3.0]
    light:
      brightness: [0, 100]
    cover:
      position: [0, 100]
    media:
      volume: [0, 100]
  prediction_enabled: false                  # Proaktive Konflikt-Vorhersage
  prediction_window_seconds: 180             # Zeitfenster fuer Vorhersage
maintenance:
  enabled: true
  config_file: config/maintenance.yaml
self_optimization:
  enabled: false
  analysis_interval: weekly
  approval_mode: manual
  max_proposals_per_cycle: 3
  model: qwen3.5:9b
  rollback:
    enabled: true
    max_snapshots: 20
    snapshot_on_every_edit: true
  parameter_bounds:
    sarcasm_level:
      min: 1
      max: 5
    opinion_intensity:
      min: 0
      max: 3
    max_response_sentences:
      min: 1
      max: 5
    formality_min:
      min: 10
      max: 80
    formality_start:
      min: 30
      max: 100
  immutable_keys:
  - trust_levels
  - security
  - autonomy
  - models
  - dashboard
  - response_filter.banned_phrases
  - response_filter.banned_starters
self_automation:
  enabled: true
  max_per_day: 5
  model: qwen3.5:9b
  templates_file: config/automation_templates.yaml
# --- Kamera-Integration ---
cameras:
  enabled: true
  vision_model: llava
  camera_map: {}
    # haustuer: camera.haustuer
    # garage: camera.garage
# --- Energie-Optimierung ---
energy:
  enabled: true
  entities:
    electricity_price: ''
    total_consumption: ''
    solar_production: ''
    grid_export: ''
  thresholds:
    price_low_cent: 15
    price_high_cent: 35
    solar_high_watts: 2000
    anomaly_increase_percent: 30
  price_forecast_enabled: false
  price_entity: ''                           # z.B. sensor.electricity_price
  solar_forecast_enabled: false
  solar_entity: ''                           # z.B. sensor.solar_power
  load_shed_price_cent: 40                   # Preis-Schwelle fuer Last-Abschaltung (ct/kWh)
  # Intelligente Last-Priorisierung: Bei hohem Strompreis abschalten nach Prioritaet
  load_priorities:
    essential: []                            # Nie abschalten (Kuehlschrank, Server, NAS)
    comfort:                                 # Reduzieren bei sehr hohem Preis
    - "climate.*"
    - "light.*"
    entertainment:                           # Zuerst abschalten
    - "media_player.*"
    - "switch.gaming*"
    - "switch.tv*"
# --- Geo-Fence / Proximity ---
geo_fence:
  approaching_km: 2.0
  arriving_km: 0.5
# --- Notfall-Protokolle ---
emergency_protocols: {}
  # fire:
  #   actions:
  #     - {domain: light, service: turn_on, target: all}
  #     - {domain: lock, service: unlock, target: all}
  #     - {domain: notify, service: notify, data: {message: "FEUERALARM!"}}
# --- Lern-Beobachter ---
learning:
  enabled: true
  min_repetitions: 3
  time_window_minutes: 30
# --- Benachrichtigungen ---
notifications:
  channels: {}
    # tts:
    #   preferred: true
    #   quiet_hours: [23, 7]
    #   urgency_min: low
    # push:
    #   preferred: false
    #   urgency_min: medium
  dedup:
    enabled: true
    similarity_threshold: 0.85    # Cosinus-Schwelle (0.7-0.95)
    buffer_size: 20               # Max. Eintraege im Vergleichs-Buffer
    window_minutes: 30            # Zeitfenster fuer Duplikat-Erkennung
# --- Urlaubs-Simulation ---
vacation_simulation:
  morning_hour: 7
  evening_hour: 18
  night_hour: 23
  variation_minutes: 30
  use_learned_patterns: true                 # Gelernte Muster statt Zufall
# --- Wetter-Warnungen ---
weather_warnings:
  enabled: true
  temp_high: 35
  temp_low: -5
  wind_speed_high: 60
  warn_conditions:
  - lightning
  - lightning-rainy
  - hail
  - exceptional
# --- Bedrohungserkennung ---
threat_assessment:
  enabled: true
  auto_execute_playbooks: false              # Sicherheits-Default: aus
  night_start_hour: 22
  night_end_hour: 6
  motion_cooldown_minutes: 30
  state_max_age_minutes: 10
  emergency_autonomy_boost: false            # Autonomie-Boost bei Notfall
  emergency_boost_duration_min: 15
  # Externe Eskalationskette: Notfall-Kontakte bei Critical ohne ACK
  emergency_contacts: []
    # - name: Partner
    #   ha_notify_target: notify.mobile_app_partner
    #   delay_minutes: 0
    # - name: Nachbar
    #   ha_notify_target: notify.mobile_app_nachbar
    #   delay_minutes: 2
# --- Wirkungstracker ---
outcome_tracker:
  enabled: true
  observation_delay_seconds: 180
  max_results: 500
  calibration_min: 0.5
  calibration_max: 1.5
  anticipation_feedback: true                # Anticipation-Feedback aktiv
  success_confidence_boost: 0.1
  failure_confidence_penalty: 0.15
  learning_observer_feedback: true           # Lern-Observer Feedback aktiv
  learning_boost: 0.1
# --- Korrektur-Gedaechtnis ---
correction_memory:
  enabled: true
  max_entries: 200
  max_context_entries: 3
  cross_domain_rules: true                   # Domain-uebergreifende Regeln
# --- Routine-Anomalie-Erkennung ---
routine_anomaly:
  enabled: false
  min_confidence: 0.8
  grace_period_minutes: 30
  max_daily_checks: 2
  min_pattern_days: 14
# --- Wetter-Vorhersage ---
weather_forecast:
  enabled: false
  lookahead_hours: 6
  entity: weather.home
# --- Stimmungs-Reaktion ---
mood_reaction:
  enabled: true
  frustration_sarcasm_reduction: 2           # Sarkasmus-Stufen-Reduktion bei Stress
  frustration_threshold: 2                   # 1=leicht, 2=mittel, 3=stark
# --- Jarvis-Innenleben ---
inner_state:
  mood_decay_enabled: true
  mood_decay_minutes: 30
  emotion_blending: false                    # Mehrere Emotionen gleichzeitig
# --- Semantisches Gedaechtnis ---
semantic_memory:
  fact_versioning: false                     # Fakt-Versionierung statt Ueberschreiben
  contradiction_query: true                  # Bei Widerspruechen nachfragen
  contradiction_confirmation: false          # Widersprueche dem User vorlegen statt auto-ueberschreiben
# --- Was-Waere-Wenn Simulation ---
whatif_simulation:
  strompreis_kwh: 0.30
  gaspreis_kwh: 0.08
  proactive_enabled: false                   # Proaktive Vorschlaege
  proactive_min_confidence: 0.7
# --- Web-Suche ---
web_search:
  enabled: false
  engine: searxng
  searxng_url: http://localhost:8888
  max_results: 5
  timeout_seconds: 10
